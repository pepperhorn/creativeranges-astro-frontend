---
export const prerender = process.env.ASTRO_OUTPUT === 'static';

import Layout from '@/layouts/BaseLayout.astro';
import { fetchPostBySlug, fetchRelatedPosts, fetchAuthorById, fetchAllPosts } from '@/lib/directus/fetchers';
import { getDirectusAssetURL } from '@/lib/directus/directus-utils';
import BlogPostClient from '@/components/layout/BlogPostClient';
import type { Post } from '@/types/directus-schema';

// Generate static paths for all published posts (only used when prerender is true)
export async function getStaticPaths() {
  // This function will only be called when prerender is true
  try {
    const posts = await fetchAllPosts();
    return posts.map((post) => ({
      params: { slug: post.slug },
      props: { post },
    }));
  } catch (error) {
    console.error('Error generating static paths for posts:', error);
    return [];
  }
}

// Get post data from props (for static generation) or fetch it (for server mode)
const slugParam = Astro.params.slug;
const slug = Array.isArray(slugParam)
  ? slugParam.join('/')
  : typeof slugParam === 'string'
  ? slugParam
  : '';

// Ensure we have a valid slug
if (!slug) {
  return Astro.redirect('/404');
}

const query = Astro.url.searchParams;
const isPreview = query.get("preview") === "true";
const authToken = query.get("token") || null;

// Use static post data if available (static mode), otherwise fetch it (server mode)
let post: Post | null = null;

// In static mode, post data comes from props
if (process.env.ASTRO_OUTPUT === 'static') {
  try {
    const { post: staticPost } = Astro.props;
    post = staticPost || null;
  } catch (error) {
    console.error('Error accessing static post data:', error);
  }
}

// If no static post data, fetch it (server mode or fallback)
if (!post) {
  try {
    post = await fetchPostBySlug(slug as string, isPreview, authToken);
  } catch (error) {
    console.error('Error loading post:', error);
    post = null;
  }
}

if (!post) {
  return Astro.redirect('/404');
}

const relatedPosts = await fetchRelatedPosts(post.id);
const author = post.author ? await fetchAuthorById(post.author as string) : null;
const authorName = [author?.first_name, author?.last_name].filter(Boolean).join(' ');
const siteURL = import.meta.env.PUBLIC_SITE_URL || '';
const postUrl = `${siteURL}/news/${slug}`;
const ogImage = post.image ? getDirectusAssetURL(post.image as string) : null;

const metadata = {
  title: post?.seo?.title ?? post.title ?? '',
  description: post?.seo?.meta_description ?? '',
  openGraph: {
    title: post?.seo?.title ?? post.title ?? '',
    description: post?.seo?.meta_description ?? '',
    url: postUrl,
    type: 'article',
    images: ogImage ? [{ url: ogImage }] : undefined,
  },
};
---
<Layout metadata={metadata}>
    <BlogPostClient
    client:load
    initialPost={post}
    relatedPosts={relatedPosts}
    author={author}
    authorName={authorName}
    postUrl={postUrl}
    slug={slug}
    token={authToken}
    isDraft={isPreview}
  />
</Layout>
